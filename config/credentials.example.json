{
  "sites": {
    "yoursite.com": {
      "baseUrl": "https://yoursite.com",
      "accounts": {
        "admin": {
          "loginUrl": "/admin/login",
          "usernameField": "input[name='email']",
          "passwordField": "input[name='password']",
          "submitButton": "button[type='submit']",
          "username": "YOUR_ADMIN_EMAIL",
          "password": "YOUR_ADMIN_PASSWORD"
        },
        "user": {
          "loginUrl": "/login",
          "usernameField": "input[name='email']",
          "passwordField": "input[name='password']",
          "submitButton": "button[type='submit']",
          "username": "YOUR_USER_EMAIL",
          "password": "YOUR_USER_PASSWORD"
        }
      }
    }
  },
  "payment": {
    "testMode": true,
    "requireConfirmation": true,
    "cards": {
      "primary": {
        "number": "YOUR_CARD_NUMBER",
        "expiry": "MM/YY",
        "cvv": "123",
        "name": "YOUR_NAME",
        "zip": "YOUR_ZIP"
      }
    },
    "selectors": {
      "cardNumber": "input[name='cardNumber'], input[id*='card'], input[data-stripe='number']",
      "expiry": "input[name='expiry'], input[id*='expir'], input[data-stripe='exp']",
      "cvv": "input[name='cvv'], input[id*='cvv'], input[id*='cvc'], input[data-stripe='cvc']",
      "name": "input[name='cardName'], input[id*='cardholder']",
      "zip": "input[name='zip'], input[name='postalCode'], input[id*='postal']",
      "submitButton": "button[type='submit'], button.pay-button, button.checkout-button"
    }
  },
  "communications": {
    "email": {
      "address": "your-email@example.com",
      "apiEndpoint": "https://your-email-api.com/inbox",
      "apiKey": "YOUR_EMAIL_API_KEY",
      "pollInterval": 30000
    },
    "sms": {
      "phoneNumber": "+1234567890",
      "apiEndpoint": "https://api.twilio.com/messages",
      "apiKey": "YOUR_TWILIO_API_KEY",
      "pollInterval": 30000
    },
    "fax": {
      "faxNumber": "+1234567890",
      "apiEndpoint": "https://api.efax.com/inbound",
      "apiKey": "YOUR_EFAX_API_KEY",
      "pollInterval": 60000
    }
  }
}
