# API key for authenticating requests to Khai's REST API
# When set, all /api/* endpoints require X-Khai-Key header
# KHAI_API_KEY=your-secret-key-here

# Shared secret for HMAC-SHA256 webhook payload signing
# KHAI_WEBHOOK_SECRET=your-webhook-secret

# Enable the evaluate action (arbitrary JS execution in browser)
# Only enable if you understand the security implications
# KHAI_ALLOW_EVAL=true

# Allow navigate action to target URLs outside the configured site domain
# KHAI_ALLOW_EXTERNAL_NAV=true

# Express server port (default: 3001)
# PORT=3001

# MCP SSE server port (default: 3105)
# MCP_SSE_PORT=3105
